# ═══════════════════════════════════════════
# MIRSAD Backend — Required Environment Vars
# ═══════════════════════════════════════════

# ── News API (required for live geopolitical news) ──
# Get free key: https://newsapi.org/register
NEWS_API_KEY=""

# ── LLM Pool (at least 1 key required) ──
# Gemini keys: https://aistudio.google.com/ → Get API Key
# Grok/xAI keys: https://console.x.ai/
LLM_POOL_1_PROVIDER="gemini"
LLM_POOL_1_KEY=""
LLM_POOL_1_MODEL="gemini-2.0-flash"
LLM_POOL_1_DAILY_LIMIT=1500

# ── Data sources that need NO key ──
# yfinance: No key needed (used for Brent/WTI prices)
# Frankfurter.app: No key needed (used for INR/USD FX rate)
# Open-Meteo: No key needed (available for future weather integration)
